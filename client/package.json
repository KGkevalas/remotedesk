{
  "name": "remotedesk",
  "version": "1.0.0",
  "description": "RemoteDesk – nuotolinio valdymo programa",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:all": "electron-builder --win --linux --x64",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.remotedesk.app",
    "productName": "RemoteDesk",
    "copyright": "Copyright © 2025",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RemoteDesk",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "RemoteDesk-Portable-${version}.exe"
    },
    "compression": "maximum"
  },
  "author": {
    "name": "KGkevalas",
    "email": "kgkevalas@gmail.com"
  },
  "homepage": "https://github.com/KGkevalas/remotedesk",
  "repository": {
    "type": "git",
    "url": "https://github.com/KGkevalas/remotedesk.git"
  }
}